{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/seed-refresh",
      "schedule": "*/15 * * * 1-6"
    },
    {
      "path": "/api/aida/tick",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "app/api/seed-refresh/route.ts": {
      "maxDuration": 60
    },
    "app/api/aida/tick/route.ts": {
      "maxDuration": 30
    }
  }
}
