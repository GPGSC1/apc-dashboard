{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/seed-refresh?mode=catchup",
      "schedule": "0 9 * * 1-6"
    },
    {
      "path": "/api/seed-refresh",
      "schedule": "*/5 * * * 1-6"
    },
    {
      "path": "/api/aida/tick",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cs/daily-pull",
      "schedule": "15 13 * * 1-6"
    }
  ],
  "functions": {
    "app/api/seed-refresh/route.ts": {
      "maxDuration": 300
    },
    "app/api/aida/tick/route.ts": {
      "maxDuration": 30
    },
    "app/api/cs/daily-pull/route.ts": {
      "maxDuration": 120
    }
  }
}
